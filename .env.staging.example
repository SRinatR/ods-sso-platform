ENV=staging
ISSUER=https://staging.api.ods.uz
ACCOUNT_URL=https://staging.account.ods.uz
PARTNERS_URL=https://staging.partners.ods.uz
API_URL=https://staging.api.ods.uz
API_DOMAIN=staging.api.ods.uz
ACCOUNT_DOMAIN=staging.account.ods.uz
PARTNER_DOMAIN=staging.partners.ods.uz
ALLOWED_ORIGINS=https://staging.account.ods.uz,https://staging.partners.ods.uz
ALLOWED_ORIGIN_PATTERNS=https://*.staging.ods.uz
SESSION_COOKIE_DOMAIN=staging.ods.uz
ACME_EMAIL=security@ods.uz

POSTGRES_USER=ods
POSTGRES_PASSWORD=
POSTGRES_DB=ods_sso
DATABASE_URL=jdbc:postgresql://postgres:5432/ods_sso
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
TRACING_SAMPLE_RATE=0.1

SESSION_SECRET=
TOKEN_PEPPER=
TOTP_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ods-platform-1
REQUIRE_EMAIL_VERIFICATION=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=no-reply@ods.uz
MAIL_REPLY_TO=support@ods.uz

DEFAULT_TENANT=default
DB_POOL_SIZE=30
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
