# Environment: dev | staging | production
ENV=staging

# Public URLs (change per environment)
ISSUER=https://staging.api.ods.uz
ACCOUNT_URL=https://staging.account.ods.uz
API_URL=https://staging.api.ods.uz

# Database
POSTGRES_USER=ods
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=ods_sso
DATABASE_URL=postgresql+asyncpg://ods:change_me_postgres@postgres:5432/ods_sso

# Redis
REDIS_URL=redis://redis:6379/0

# Keycloak (internal)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ods
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak
KEYCLOAK_CLIENT_ID=ods-backend
KEYCLOAK_CLIENT_SECRET=change_me_backend_secret

# Platform JWT (RS256) — generate with: openssl genrsa 2048
# Paste PEM contents on one line with \n or use files in secrets/
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Tatarlar staging client (generated on first seed if empty)
TATARLAR_CLIENT_SECRET=

# Session cookie
SESSION_SECRET=change_me_session_secret_min_32_chars

# Mail (optional for pilot)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@ods.uz
