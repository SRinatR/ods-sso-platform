ENV=dev
ISSUER=http://localhost:8080
ACCOUNT_URL=http://account.localhost
API_URL=http://localhost:8080
API_DOMAIN=localhost
ACCOUNT_DOMAIN=account.localhost
ALLOWED_ORIGINS=http://account.localhost,http://localhost:3000
ALLOWED_ORIGIN_PATTERNS=http://*.localhost
SESSION_COOKIE_DOMAIN=

POSTGRES_USER=ods
POSTGRES_PASSWORD=ods_dev_password
POSTGRES_DB=ods_sso
DATABASE_URL=jdbc:postgresql://postgres:5432/ods_sso
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
TRACING_SAMPLE_RATE=0.1

SESSION_SECRET=replace-with-at-least-32-random-characters
TOKEN_PEPPER=replace-with-an-independent-32-character-secret
TOTP_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ods-platform-1
REQUIRE_EMAIL_VERIFICATION=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_RECONCILE=false
TATARLAR_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=no-reply@ods.uz
MAIL_REPLY_TO=support@ods.uz

MINIO_ROOT_USER=ods_minio
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
MINIO_BUCKET=ods-backups
BACKUP_DIR=/var/backups/ods-platform
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=
RUNTIME_ENV_FILE=.env

DEFAULT_TENANT=default
DB_POOL_SIZE=20
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-before-production
