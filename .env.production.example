ENV=production
PUBLIC_DOMAIN=auth.ods.uz
ROOT_DOMAIN=ods.uz
WWW_DOMAIN=www.ods.uz
ACCOUNT_DOMAIN=accounts.ods.uz
ADMIN_DOMAIN=admin.ods.uz
API_DOMAIN=api.ods.uz
DOCS_DOMAIN=docs.ods.uz
STATUS_DOMAIN=status.ods.uz
SSO_DOMAIN=sso.ods.uz
SCIM_DOMAIN=scim.ods.uz
WEBHOOKS_DOMAIN=webhooks.ods.uz
ISSUER=https://auth.ods.uz
ACCOUNT_URL=https://auth.ods.uz
API_URL=https://auth.ods.uz
ROOT_URL=https://ods.uz
ACCOUNTS_URL=https://accounts.ods.uz
ADMIN_URL=https://admin.ods.uz
ALLOWED_ORIGINS=https://ods.uz,https://auth.ods.uz,https://accounts.ods.uz,https://admin.ods.uz
ALLOWED_ORIGIN_PATTERNS=https://*.ods.uz
SESSION_COOKIE_DOMAIN=ods.uz
ACME_EMAIL=admin@ods.uz

POSTGRES_USER=ods
POSTGRES_PASSWORD=
POSTGRES_DB=ods_sso
DATABASE_URL=jdbc:postgresql://postgres:5432/ods_sso
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_ENABLED=false
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
TRACING_SAMPLE_RATE=0.05

SESSION_SECRET=
TOKEN_PEPPER=
TOTP_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ods-platform-1
REQUIRE_EMAIL_VERIFICATION=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_RECONCILE=false
TATARLAR_CLIENT_SECRET=

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=ODS Identity <no-reply@ods.uz>
MAIL_REPLY_TO=support@ods.uz

DEFAULT_TENANT=default
TRUSTED_PROXY_COUNT=1
DB_POOL_SIZE=10
BACKEND_CPUS=1.0
BACKEND_CPUSET=0
BACKUP_DIR=/var/backups/ods-platform
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=ods-backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=
RUNTIME_ENV_FILE=/etc/ods-platform/production.env
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
