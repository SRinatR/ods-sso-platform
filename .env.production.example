ENV=production
PUBLIC_DOMAIN=auth.ods.uz
ROOT_DOMAIN=ods.uz
WWW_DOMAIN=www.ods.uz
ACCOUNT_DOMAIN=accounts.ods.uz
ADMIN_DOMAIN=admin.ods.uz
API_DOMAIN=api.ods.uz
DOCS_DOMAIN=docs.ods.uz
STATUS_DOMAIN=status.ods.uz
SSO_DOMAIN=sso.ods.uz
SCIM_DOMAIN=scim.ods.uz
WEBHOOKS_DOMAIN=webhooks.ods.uz
ISSUER=https://auth.ods.uz
ACCOUNT_URL=https://auth.ods.uz
API_URL=https://auth.ods.uz
ALLOWED_ORIGINS=https://auth.ods.uz
ACME_EMAIL=admin@ods.uz

POSTGRES_USER=ods
POSTGRES_PASSWORD=
POSTGRES_DB=ods_sso
DATABASE_URL=jdbc:postgresql://postgres:5432/ods_sso
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_ENABLED=false
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
TRACING_SAMPLE_RATE=0.05

SESSION_SECRET=
TOKEN_PEPPER=
TOTP_ENCRYPTION_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ods-platform-1
REQUIRE_EMAIL_VERIFICATION=false

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
TATARLAR_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=no-reply@ods.uz

DEFAULT_TENANT=default
TRUSTED_PROXY_COUNT=1
DB_POOL_SIZE=10
BACKEND_CPUS=1.0
BACKEND_CPUSET=0
BACKUP_DIR=/var/backups/ods-platform
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
