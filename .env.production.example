SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=no-reply@ods.uz

DEFAULT_TENANT=default
TRUSTED_PROXY_COUNT=1
DB_POOL_SIZE=10
